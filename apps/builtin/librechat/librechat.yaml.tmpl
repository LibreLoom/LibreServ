# LibreChat Configuration - generated by LibreServ
# See https://www.librechat.ai/docs/configuration/librechat_yaml

version: 1.2.8
cache: true

registration:
  socialLogins: []
  allowedDomains: []

rateLimits:
  fileUploads:
    ipMax: 100
    ipWindowInMinutes: 60
    userMax: 50
    userWindowInMinutes: 60
  conversationsImport:
    ipMax: 100
    ipWindowInMinutes: 60
    userMax: 50
    userWindowInMinutes: 60

{{- if .ollama_base_url }}
endpoints:
  custom:
    - name: "Ollama"
      apiKey: "ollama"
      baseURL: "{{.ollama_base_url}}/v1"
      models:
        default: ["llama3.2", "llama3.1", "mistral", "codellama", "phi"]
        fetch: true
      titleConvo: true
      titleModel: "llama3.2"
      summarize: false
      summaryModel: "llama3.2"
      forcePrompt: false
      modelDisplayLabel: "Ollama"
{{- end }}
