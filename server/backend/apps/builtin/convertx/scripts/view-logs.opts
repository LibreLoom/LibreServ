name: view-logs
label: "View Logs"
description: "View ConvertX application logs"

options:
  - name: lines
    type: number
    label: "Number of lines"
    description: "How many lines to show"
    default: 50
    min: 10
    max: 1000
    required: false

  - name: filter
    type: string
    label: "Filter pattern"
    description: "Only show lines matching regex"
    required: false

execution:
  timeout: 60
  stream_output: true
