#!/bin/bash
# view-logs - View ConvertX application logs

set -euo pipefail

CONFIG_FILE="${1:-}"
if [[ -z "$CONFIG_FILE" ]]; then
    echo "ERROR: Config file path required"
    exit 1
fi

LINES=$(jq -r '.options.lines // 50' "$CONFIG_FILE")
FILTER=$(jq -r '.options.filter // ""' "$CONFIG_FILE")
APP_DATA_PATH=$(jq -r '.app_data_path' "$CONFIG_FILE")

LOG_FILE="$APP_DATA_PATH/logs/app.log"

if [[ ! -f "$LOG_FILE" ]]; then
    echo "No log file found at: $LOG_FILE"
    echo "Checking container logs instead..."
    CONTAINER_NAME=$(jq -r '.instance_id' "$CONFIG_FILE")-convertx
    docker logs --tail "$LINES" "$CONTAINER_NAME" 2>&1
    exit $?
fi

if [[ -n "$FILTER" ]]; then
    tail -n "$LINES" "$LOG_FILE" | grep "$FILTER" || echo "No matching lines found"
else
    tail -n "$LINES" "$LOG_FILE"
fi

exit 0
