#!/bin/bash
# system-repair - Frigate repair script
# Handles common issues with Frigate

set -euo pipefail

CONFIG_FILE="${1:-}"
if [[ -z "$CONFIG_FILE" ]]; then
    echo "ERROR: Config file path required"
    exit 1
fi

# Parse config
APP_DATA_PATH=$(jq -r '.app_data_path' "$CONFIG_FILE")
INSTANCE_ID=$(jq -r '.instance_id' "$CONFIG_FILE")

echo ">> [Frigate] Starting repair..."
echo ">> Instance ID: $INSTANCE_ID"
echo ">> Data path: $APP_DATA_PATH"

# Fix permissions
echo ">> Fixing permissions..."
if [[ -d "$APP_DATA_PATH/frigate" ]]; then
    chmod -R 755 "$APP_DATA_PATH/frigate"
    echo ">> Permissions fixed"
fi

# Check for config file
CONFIG_YML="$APP_DATA_PATH/frigate/config/config.yml"
if [[ ! -f "$CONFIG_YML" ]]; then
    echo ">> WARNING: config.yml not found at $CONFIG_YML"
    echo ">> You need to create this file to configure cameras"
else
    echo ">> Config file found at: $CONFIG_YML"
    
    # Validate YAML syntax (basic check)
    if command -v yq &> /dev/null; then
        if yq eval '.' "$CONFIG_YML" > /dev/null 2>&1; then
            echo ">> Config YAML syntax is valid"
        else
            echo ">> WARNING: Config YAML syntax may be invalid"
        fi
    fi
fi

# Check directories
echo ">> Checking directories..."
for dir in config media/recordings media/clips media/exports cache logs backups; do
    full_path="$APP_DATA_PATH/frigate/$dir"
    if [[ ! -d "$full_path" ]]; then
        echo ">> Creating missing directory: $dir"
        mkdir -p "$full_path"
    fi
done

# Clear cache if needed
CACHE_DIR="$APP_DATA_PATH/frigate/cache"
if [[ -d "$CACHE_DIR" ]]; then
    echo ">> Clearing cache directory..."
    rm -rf "$CACHE_DIR"/*
    echo ">> Cache cleared"
fi

echo ">> [Frigate] Repair completed successfully"
exit 0
