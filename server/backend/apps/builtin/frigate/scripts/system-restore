#!/bin/bash
# system-restore - Frigate restore script
# Restores Frigate from a backup

set -euo pipefail

CONFIG_FILE="${1:-}"
if [[ -z "$CONFIG_FILE" ]]; then
    echo "ERROR: Config file path required"
    exit 1
fi

# Parse config
APP_DATA_PATH=$(jq -r '.app_data_path' "$CONFIG_FILE")
INSTANCE_ID=$(jq -r '.instance_id' "$CONFIG_FILE")
BACKUP_PATH=$(jq -r '.backup_path // empty' "$CONFIG_FILE")

if [[ -z "$BACKUP_PATH" ]]; then
    echo "ERROR: backup_path required in config"
    exit 1
fi

if [[ ! -d "$BACKUP_PATH" ]]; then
    echo "ERROR: Backup directory not found: $BACKUP_PATH"
    exit 1
fi

echo ">> [Frigate] Starting restore..."
echo ">> Instance ID: $INSTANCE_ID"
echo ">> Backup path: $BACKUP_PATH"
echo ">> Data path: $APP_DATA_PATH"

# Validate backup
if [[ ! -f "$BACKUP_PATH/backup-metadata.json" ]]; then
    echo "ERROR: Invalid backup - metadata file not found"
    exit 1
fi

# Check if app matches
BACKUP_APP=$(jq -r '.app_id' "$BACKUP_PATH/backup-metadata.json")
if [[ "$BACKUP_APP" != "frigate" ]]; then
    echo "ERROR: Backup is for app '$BACKUP_APP', not 'frigate'"
    exit 1
fi

echo ">> Restoring configuration..."
if [[ -d "$BACKUP_PATH/config" ]]; then
    mkdir -p "$APP_DATA_PATH/frigate/config"
    cp -r "$BACKUP_PATH/config"/* "$APP_DATA_PATH/frigate/config/"
fi

echo ">> Restoring exports..."
if [[ -d "$BACKUP_PATH/exports" ]]; then
    mkdir -p "$APP_DATA_PATH/frigate/media/exports"
    cp -r "$BACKUP_PATH/exports"/* "$APP_DATA_PATH/frigate/media/exports/"
fi

# Set proper permissions
chmod -R 755 "$APP_DATA_PATH/frigate"

echo ">> [Frigate] Restore completed successfully"
exit 0
