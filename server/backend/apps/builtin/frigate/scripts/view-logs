#!/bin/bash
# view-logs - View Frigate application logs

set -euo pipefail

CONFIG_FILE="${1:-}"
if [[ -z "$CONFIG_FILE" ]]; then
    echo "ERROR: Config file path required"
    exit 1
fi

INSTANCE_ID=$(jq -r '.instance_id' "$CONFIG_FILE")
CONTAINER_NAME="${INSTANCE_ID}-frigate"

echo ">> [Frigate] Viewing logs for container: $CONTAINER_NAME"
echo ">>"

# Check if container is running
if ! docker ps --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"; then
    echo ">> WARNING: Container $CONTAINER_NAME is not running"
    echo ">> Showing last 100 lines from previous logs:"
    docker logs --tail 100 "$CONTAINER_NAME" 2>&1 || echo ">> No previous logs available"
else
    docker logs --tail 100 -f "$CONTAINER_NAME" 2>&1
fi

exit 0
